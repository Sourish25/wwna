[node name="Note3" parent="Props" instance=ExtResource("7_note_tscn")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 15.5, 0.81, -1.0)
note_contents = "Day 12: Dr. Miller's experiments are out of control. He claims the patient's consciousness has successfully anchored to a porcelain doll, but it feels like he has opened a doorway to something far more ancient. Security keys have been restricted to the East block."

[node name="Note4" parent="Props" instance=ExtResource("7_note_tscn")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -15, 0.81, 4.0)
note_contents = "Day 29: The entity is drawing power from the electrical grid. If you hear her shriek nearby, do not run down the straight corridors, you will not outrun her. Get low and slide underneath the large tables in the Cafeteria. She cannot see you if you remain crouched and silent."

[node name="Note5" parent="Props" instance=ExtResource("7_note_tscn")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 18.5, 0.1, -15.0)
note_contents = "Day 48: The sacrificial chamber door at the North wing is locked tight. The Altar key is stored in the lockers of the East wing. But be careful... the Boiler Key was taken by security to the East guard desk."
